{
  "title": "Alvus Overview",
  "uid": "alvus-overview",
  "tags": ["alvus", "proxy"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(alvus_requests_total[$__rate_interval]))",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Key Pool State",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "targets": [
        {
          "expr": "alvus_keypool_keys{state=\"active\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "alvus_keypool_keys{state=\"cooling\"}",
          "legendFormat": "Cooling",
          "refId": "B"
        },
        {
          "expr": "alvus_keypool_keys{state=\"disabled\"}",
          "legendFormat": "Disabled",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Upstream Circuit Breaker",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 1.5 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "CLOSED", "color": "green" },
                "1": { "text": "OPEN", "color": "red" },
                "2": { "text": "HALF_OPEN", "color": "orange" }
              }
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "alvus_upstream_cb_state",
          "legendFormat": "State",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Health Check Success Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "green", "value": 0.9 }
            ]
          },
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(alvus_healthcheck_probes_total{status=\"ok\"}[$__rate_interval])) / (sum(rate(alvus_healthcheck_probes_total{status=\"ok\"}[$__rate_interval])) + sum(rate(alvus_healthcheck_probes_total{status=\"fail\"}[$__rate_interval])))",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(alvus_request_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(alvus_request_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(alvus_request_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Request Rate by Key Index",
      "type": "bargauge",
      "gridPos": { "h": 9, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "min": 0
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "targets": [
        {
          "expr": "sum(rate(alvus_requests_total[$__rate_interval])) by (key_index)",
          "legendFormat": "Key {{key_index}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Upstream Errors by Type",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "fillOpacity": 50
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "rate(alvus_upstream_errors_total{type=\"network\"}[$__rate_interval])",
          "legendFormat": "Network",
          "refId": "A"
        },
        {
          "expr": "rate(alvus_upstream_errors_total{type=\"rate_limited\"}[$__rate_interval])",
          "legendFormat": "Rate Limited",
          "refId": "B"
        },
        {
          "expr": "rate(alvus_upstream_errors_total{type=\"auth_rejected\"}[$__rate_interval])",
          "legendFormat": "Auth Rejected",
          "refId": "C"
        },
        {
          "expr": "rate(alvus_upstream_errors_total{type=\"server_error\"}[$__rate_interval])",
          "legendFormat": "Server Error",
          "refId": "D"
        }
      ]
    },
    {
      "id": 8,
      "title": "Health Check Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "rate(alvus_healthcheck_duration_seconds_sum[$__rate_interval]) / rate(alvus_healthcheck_duration_seconds_count[$__rate_interval])",
          "legendFormat": "Average",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Request Status Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "fillOpacity": 50
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "rate(alvus_requests_total{status=\"2xx\"}[$__rate_interval])",
          "legendFormat": "2xx",
          "refId": "A"
        },
        {
          "expr": "rate(alvus_requests_total{status=\"4xx\"}[$__rate_interval])",
          "legendFormat": "4xx",
          "refId": "B"
        },
        {
          "expr": "rate(alvus_requests_total{status=\"5xx\"}[$__rate_interval])",
          "legendFormat": "5xx",
          "refId": "C"
        }
      ]
    }
  ]
}
