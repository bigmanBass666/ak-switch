# Auto-detect text files and normalize line endings
* text=auto

# Go source files: force LF (gofmt outputs LF, prevents CRLF issues with Claude Code Edit tool)
*.go text eol=lf

# CLAUDE.md: force LF in repo (CRLF originally committed)
CLAUDE.md text eol=lf

# HTML dashboard: force LF
cmd/akswitch/dashboard.html text eol=lf