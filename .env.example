# ─────────────────────────────────────────────
# Alvus Configuration
# ─────────────────────────────────────────────

# Your API keys, comma-separated (REQUIRED)
# Get free NVIDIA NIM keys at: https://build.nvidia.com
API_KEYS=nvapi-xxxxxxxxxxxx,nvapi-yyyyyyyyyyyy,nvapi-zzzzzzzzzzzz

# Port for the proxy to listen on
PORT=3000

# Upstream API base URL
# Default: NVIDIA NIM (LLMs and chat models)
TARGET_BASE_URL=https://integrate.api.nvidia.com/v1

# Upstream base URL for image/genai requests (/genai/ paths)
# Default: NVIDIA NIM visual models host
GENAI_BASE_URL=https://ai.api.nvidia.com

# How many seconds to cool a key after a 429 response
# 60s works well for most free-tier providers
COOLDOWN_SEC=60

# ── Key Persistence ───────────────────────────
# JSON file for key state persistence (disabled status, order).
# Created automatically on first startup from API_KEYS.
KEYS_FILE=keys.json

# AES-256 encryption key for keys.json (optional).
# 64 hex characters = 32 bytes. If unset, keys.json is stored in plaintext.
# KEYS_ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# ── Circuit Breaker ───────────────────────────────
BACKOFF_CAP_SEC=120        # Key 退避上限(秒)，达到此值自动禁用
BACKOFF_MULTIPLIER=2       # 指数退避倍数
CB_RESET_SEC=30            # 上游熔断器 OPEN→HALF_OPEN 超时(秒)
UPSTREAM_CB_THRESHOLD=5    # 上游熔断器连续失败触发阈值