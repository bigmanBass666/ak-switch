.env

alvus
alvus.exe
alvus-linux-386

# User-specific config (use manage.example.json as template)
manage.json

# Provider directories (each user creates their own)
proxies/

# Runtime logs
logs/

# Backup files
*.exe~
*.exe

# Build output
alvus_proxy.exe

# Load test results (binary reports, keep .gitkeep)
test/load/results/*.bin
test/load/results/*.html

# IDE / project config
.omc/
.playwright-mcp/

# Spec documents (project-level, not committed to repo)
.agents/

# Docker volumes (local runtime state — do not commit)
data/
prometheus-data/
grafana-data/

